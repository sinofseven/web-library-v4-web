{
  "name": "web-library-v4-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "envsubst < wrangler.toml > wrangler.toml.tmp && mv wrangler.toml.tmp wrangler.toml && tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier -w src/ functions/ eslint.config.js vite.config.ts",
    "preview": "vite preview",
    "dev:app": "vite",
    "dev:functions": "wrangler pages dev dist --persist-to .wrangler/state",
    "dev:kv-seed": "wait-on tcp:localhost:8786 && wrangler kv bulk put --local --binding web_library_v4 --persist-to .wrangler/state local-kv/seed.json",
    "dev": "mkdir -p dist && concurrently \"npm run dev:app\" \"npm run dev:functions\" \"npm run dev:kv-seed\""
  },
  "dependencies": {
    "@yui540/comimi": "^0.13.0",
    "@yui540/comimi-react": "^0.2.3",
    "bulma": "^1.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10",
    "wrangler": "^4.100.0"
  }
}
